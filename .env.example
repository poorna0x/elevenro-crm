# =============================================================================
# Eleven RO website (booking only). Admin/technician CRM: https://hydrogenro.com
# Copy to .env.local and set the same names in Netlify → Production.
# =============================================================================

# --- Supabase (same project as Hydrogen RO) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Build (Production): tag booking intents for Eleven RO
VITE_WEBSITE_BOOKING_SITE_KEY=elevenro
# Server-only (required for /book — Netlify functions, not in browser):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- ALTCHA (required for booking in production) ---
# ALTCHA_HMAC_KEY=

# --- Cloudinary (optional — booking photos) ---
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
# VITE_CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Google Maps (optional) ---
# VITE_GOOGLE_MAPS_API_KEY=

# --- Email (booking confirmations) ---
# HOSTINGER_EMAIL_USER=
# HOSTINGER_EMAIL_PASS=

# Internal "new booking" notification (sent when a booking is confirmed).
# Defaults to poorna8105@gmail.com if unset. Comma-separated for multiple.
# BOOKING_NOTIFY_EMAIL=poorna8105@gmail.com

# --- Production CORS (Netlify functions) ---
# ALLOWED_ORIGINS=https://elevenro.com,https://www.elevenro.com

# After deploy: bash scripts/check-elevenro-booking-deploy.sh https://elevenro.com

# --- Booking phone OTP (Firebase) — same project as Hydrogen RO ---
# VITE_OTP_ENABLED=true
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=hydrogenro-otp.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=hydrogenro-otp
# VITE_FIREBASE_APP_ID=
#
# Server-only (Netlify, never VITE_*): require verified phone on booking-job-create
# OTP_ENFORCED=true
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
